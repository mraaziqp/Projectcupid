rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isReader() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'reader';
    }

    function isAllowedUser() {
      return isAdmin() || isReader();
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && (
        request.resource.data.role == 'reader' || 
        (request.resource.data.role == 'admin' && request.auth.token.email == 'backupe9@gmail.com')
      );
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // App Collections
    match /letters/{docId} {
      allow read, write: if isAllowedUser();
    }
    match /letter_replies/{docId} {
      allow read, write: if isAllowedUser();
    }
    match /vault/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }
    match /cycle_logs/{docId} {
      allow read, write: if isAllowedUser();
    }
    match /weather/{docId} {
      allow read, write: if isAllowedUser();
    }
    match /us_drops/{docId} {
      allow read, write: if isAllowedUser();
    }
    match /care_quests/{docId} {
      allow read, write: if isAllowedUser();
    }
    match /notifications/{docId} {
      allow read, write: if isAllowedUser();
    }
  }
}
