# Firebase Configuration
VITE_FIREBASE_VAPID_KEY=your_firebase_web_push_vapid_key

# Firebase Admin SDK (for server-side push notifications)
# Download your service account JSON from Firebase Console → Project Settings → Service accounts
# Paste the entire JSON as a single-line string value here
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Resend Email Configuration (for notification email fallback)
# Get your API key from https://resend.com
RESEND_API_KEY=your_resend_api_key
# The "from" email address for sending notifications
# Either verify a domain or use the default resend.dev domain
RESEND_FROM_EMAIL=cupid@resend.dev

# Ollama API Configuration
OLLAMA_API_URL=https://ollama.com/api/generate
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_MODEL=llama3

# Google Cloud / Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key